generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Rsvp {
  id          Int      @id @default(autoincrement())
  code        String   @unique @default(cuid())
  name        String
  email       String
  attending   Boolean
  plusOne     Int      @default(0)
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rsvps")
}